{%- comment -%}
  SECTION: hero
  Homepage hero — dark full-bleed, headline, CTA.
  Config-driven via settings. Image is a placeholder until real photography
  of Black women is sourced. Never use stock imagery that feels extractive.
{%- endcomment -%}

<section class="hero section-pad" aria-labelledby="hero-heading">

  <div class="hero__bg" aria-hidden="true"></div>

  {%- if section.settings.hero_image != blank -%}
    <img
      class="hero__image"
      src="{{ section.settings.hero_image | img_url: '1600x' }}"
      alt="{{ section.settings.hero_image_alt | escape }}"
      loading="eager"
      fetchpriority="high"
      style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0.45;z-index:1;"
    >
  {%- else -%}
    {%- comment -%}
      Default hero image — three Black women, confident, unhurried.
      Photo: Jovaughn Stephens / Unsplash (free to use).
      Replace via Theme Editor → Hero → Hero image with licensed photography.
    {%- endcomment -%}
    <img
      src="{{ 'hero-women.jpg' | asset_url }}"
      alt="{{ section.settings.hero_image_alt | escape }}"
      loading="eager"
      fetchpriority="high"
      style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 30%;opacity:0.45;z-index:1;"
    >
  {%- endif -%}

  <div class="hero__overlay" aria-hidden="true"></div>

  <div class="container">
    <div class="hero__content">

      <p class="eyebrow hero__eyebrow">{{ section.settings.eyebrow }}</p>

      <h1 id="hero-heading" class="hero__heading">
        {{ section.settings.heading | replace: '[accent]', '<em>' | replace: '[/accent]', '</em>' }}
      </h1>

      <p class="hero__subheading">{{ section.settings.subheading }}</p>

      <div class="hero__cta-group">
        <a href="{{ section.settings.cta_primary_url }}" class="btn btn-primary btn-lg">
          {{ section.settings.cta_primary }}
        </a>
        <a href="{{ section.settings.cta_secondary_url }}" class="btn btn-outline">
          {{ section.settings.cta_secondary }}
        </a>
      </div>

      {%- if section.settings.social_proof != blank -%}
        <div class="hero__social-proof">
          <span class="hero__social-proof-divider" aria-hidden="true"></span>
          <span>{{ section.settings.social_proof }}</span>
        </div>
      {%- endif -%}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "class": "section-hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image",
      "info": "Use authentic imagery. Source from Black women photographers."
    },
    {
      "type": "text",
      "id": "hero_image_alt",
      "label": "Image alt text",
      "default": "A Black woman looking directly at camera — confident, unhurried, sovereign."
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Hormonal health for Black women"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading (wrap [accent]...[/accent] for gold text)",
      "default": "The healthcare system wasn't built with you in mind.\n[accent]For Her Throne was.[/accent]"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Daily Reign is the hormonal balance formula built specifically for the disparities Black women face — backed by NIH and CDC data, not guesswork."
    },
    {
      "type": "text",
      "id": "cta_primary",
      "label": "Primary CTA text",
      "default": "Shop Our Formulas"
    },
    {
      "type": "url",
      "id": "cta_primary_url",
      "label": "Primary CTA link",
      "default": "/collections/all"
    },
    {
      "type": "text",
      "id": "cta_secondary",
      "label": "Secondary CTA text",
      "default": "Our story"
    },
    {
      "type": "url",
      "id": "cta_secondary_url",
      "label": "Secondary CTA link",
      "default": "/pages/about"
    },
    {
      "type": "text",
      "id": "social_proof",
      "label": "Social proof line (optional)",
      "default": "Formulated from the data. Built for you."
    }
  ],
  "presets": [
    {
      "name": "Hero",
      "settings": {
        "eyebrow": "Hormonal health for Black women",
        "heading": "The healthcare system wasn't built with you in mind.\n[accent]For Her Throne was.[/accent]",
        "subheading": "Daily Reign is the hormonal balance formula built specifically for the disparities Black women face — backed by NIH and CDC data, not guesswork.",
        "cta_primary": "Shop Daily Reign — $45.00",
        "cta_secondary": "Our story",
        "social_proof": "Formulated from the data. Built for you."
      }
    }
  ]
}
{% endschema %}

{%- comment -%}
  SECTION: photo-strip
  3-photo community grid. Configurable via Theme Editor.
  Default images pulled from assets — swap via image pickers.
{%- endcomment -%}

<section class="photo-strip section-pad">
  <div class="container">

    {%- if section.settings.eyebrow != blank or section.settings.heading != blank -%}
      <header style="text-align:center;margin-bottom:2.5rem;">
        {%- if section.settings.eyebrow != blank -%}
          <p class="eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 style="font-family:var(--font-heading);font-size:clamp(1.5rem,3vw,2.25rem);">
            {{ section.settings.heading }}
          </h2>
        {%- endif -%}
      </header>
    {%- endif -%}

    <div class="photo-strip__grid">

      {%- for i in (1..3) -%}
        {%- assign img_setting = 'image_' | append: i -%}
        {%- assign alt_setting = 'alt_'   | append: i -%}
        {%- assign img = section.settings[img_setting] -%}
        {%- assign alt = section.settings[alt_setting] -%}

        <div class="photo-strip__item">
          {%- if img != blank -%}
            <img
              src="{{ img | img_url: '800x800', crop: 'center' }}"
              alt="{{ alt | escape }}"
              loading="lazy"
              width="800" height="800">
          {%- else -%}
            {%- comment -%} Fallback to default asset images {%- endcomment -%}
            {%- if i == 1 -%}
              <img src="{{ 'community-1.jpg' | asset_url }}" alt="{{ alt | default: 'Community' | escape }}" loading="lazy">
            {%- elsif i == 2 -%}
              <img src="{{ 'community-2.jpg' | asset_url }}" alt="{{ alt | default: 'Community' | escape }}" loading="lazy">
            {%- else -%}
              <img src="{{ 'community-3.jpg' | asset_url }}" alt="{{ alt | default: 'Community' | escape }}" loading="lazy">
            {%- endif -%}
          {%- endif -%}
        </div>

      {%- endfor -%}

    </div>

  </div>
</section>

<style>
  .photo-strip__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  .photo-strip__item {
    aspect-ratio: 3 / 4;
    overflow: hidden;
    border-radius: var(--card-radius);
  }
  .photo-strip__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }
  .photo-strip__item:hover img {
    transform: scale(1.04);
  }
  @media (max-width: 600px) {
    .photo-strip__grid {
      grid-template-columns: 1fr 1fr;
      gap: 0.625rem;
    }
    .photo-strip__item:last-child {
      grid-column: 1 / -1;
      aspect-ratio: 16 / 9;
    }
  }
</style>

{% schema %}
{
  "name": "Photo Strip",
  "tag": "section",
  "class": "section-photo-strip",
  "settings": [
    { "type": "text",         "id": "eyebrow",  "label": "Eyebrow label" },
    { "type": "text",         "id": "heading",  "label": "Heading" },
    { "type": "image_picker", "id": "image_1",  "label": "Photo 1" },
    { "type": "text",         "id": "alt_1",    "label": "Photo 1 alt text", "default": "A Black woman — present, confident, sovereign." },
    { "type": "image_picker", "id": "image_2",  "label": "Photo 2" },
    { "type": "text",         "id": "alt_2",    "label": "Photo 2 alt text", "default": "A Black woman — present, confident, sovereign." },
    { "type": "image_picker", "id": "image_3",  "label": "Photo 3" },
    { "type": "text",         "id": "alt_3",    "label": "Photo 3 alt text", "default": "A Black woman — present, confident, sovereign." }
  ],
  "presets": [{
    "name": "Photo Strip",
    "settings": {
      "eyebrow": "The community",
      "heading": "For women who've been overlooked long enough."
    }
  }]
}
{% endschema %}

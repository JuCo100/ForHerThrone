{%- comment -%}
  SECTION: cart-main
  Cart page — line items, totals, checkout button.
{%- endcomment -%}

<section class="cart-page section-pad">
  <div class="container" style="max-width:760px;">

    <h1 style="font-family:var(--font-heading);font-size:clamp(2rem,4vw,3rem);margin-bottom:2.5rem;">
      Your Cart
    </h1>

    {%- if cart.item_count == 0 -%}

      <div style="text-align:center;padding:4rem 0;">
        <p style="font-size:1.125rem;opacity:0.7;margin-bottom:2rem;">Your cart is empty.</p>
        <a href="/products/for-her-throne-daily-reign" class="btn btn-primary btn-lg">
          Shop Daily Reign
        </a>
      </div>

    {%- else -%}

      <form action="/cart" method="post">

        {%- comment -%} Line items {%- endcomment -%}
        <div style="display:flex;flex-direction:column;gap:1.25rem;margin-bottom:2.5rem;">
          {%- for item in cart.items -%}
            <div style="display:grid;grid-template-columns:80px 1fr auto;gap:1.25rem;align-items:center;background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--card-radius);padding:1.25rem;">

              {%- if item.image -%}
                <img src="{{ item.image | img_url: '160x160', crop: 'center' }}"
                     alt="{{ item.title | escape }}"
                     width="80" height="80"
                     style="border-radius:8px;object-fit:cover;">
              {%- else -%}
                <div style="width:80px;height:80px;background:var(--color-surface-light);border-radius:8px;"></div>
              {%- endif -%}

              <div>
                <p style="font-weight:600;margin-bottom:0.25rem;">{{ item.product.title }}</p>
                {%- unless item.variant.title == 'Default Title' -%}
                  <p style="font-size:0.875rem;opacity:0.6;margin-bottom:0.5rem;">{{ item.variant.title }}</p>
                {%- endunless -%}
                <p style="color:var(--color-accent);font-weight:600;">{{ item.price | money }}</p>
              </div>

              <div style="display:flex;flex-direction:column;align-items:flex-end;gap:0.75rem;">
                <div style="display:flex;align-items:center;gap:0.5rem;background:var(--color-surface-light);border:1px solid var(--color-border);border-radius:6px;padding:0.25rem 0.5rem;">
                  <label for="qty-{{ item.key }}" style="font-size:0.75rem;opacity:0.6;">Qty</label>
                  <input type="number"
                         id="qty-{{ item.key }}"
                         name="updates[]"
                         value="{{ item.quantity }}"
                         min="0"
                         style="width:48px;background:transparent;border:none;color:var(--color-text);text-align:center;font-family:var(--font-body);font-size:0.9375rem;outline:none;">
                </div>
                <a href="/cart/change?line={{ forloop.index }}&quantity=0"
                   style="font-size:0.75rem;opacity:0.45;text-decoration:underline;color:var(--color-text);"
                   aria-label="Remove {{ item.title }}">
                  Remove
                </a>
              </div>

            </div>
          {%- endfor -%}
        </div>

        <button type="submit" name="update" class="btn btn-outline" style="margin-bottom:2rem;">
          Update cart
        </button>

        {%- comment -%} Order summary {%- endcomment -%}
        <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--card-radius);padding:1.75rem;">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.25rem;">
            <span style="font-size:1.0625rem;">Subtotal</span>
            <span style="font-family:var(--font-heading);font-size:1.375rem;color:var(--color-accent);font-weight:700;">
              {{ cart.total_price | money }}
            </span>
          </div>
          <p style="font-size:0.8125rem;opacity:0.55;margin-bottom:1.5rem;">
            Shipping and taxes calculated at checkout.
          </p>
          <a href="/checkout" class="btn btn-primary btn-lg" style="width:100%;display:flex;justify-content:center;">
            Checkout — {{ cart.total_price | money }}
          </a>
        </div>

        {%- comment -%} FDA disclaimer required near checkout per compliance guidelines {%- endcomment -%}
        <p class="fda-disclaimer" style="margin-top:1.5rem;">
          {{ settings.fda_disclaimer }}
        </p>

      </form>

    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Cart",
  "tag": "section",
  "class": "section-cart",
  "settings": [],
  "presets": [{ "name": "Cart" }]
}
{% endschema %}

{%- comment -%}
  SECTION: cart-main
  Live-updating cart — quantity changes and removals update totals
  instantly via Shopify's Cart API (/cart/change.js).
{%- endcomment -%}


<section class="cart-page section-pad">
  <div class="container" style="max-width:760px;">

    <h1 style="font-family:var(--font-heading);font-size:clamp(2rem,4vw,3rem);margin-bottom:2.5rem;">
      Your Cart
    </h1>

    {%- if cart.item_count == 0 -%}

      <div id="cart-empty" style="text-align:center;padding:4rem 0;">
        <p style="font-size:1.125rem;opacity:0.7;margin-bottom:2rem;">Your cart is empty.</p>
        <a href="/products/{{ settings.product_handle }}" class="btn btn-primary btn-lg">
          Shop Daily Reign
        </a>
      </div>

    {%- else -%}

      <div id="cart-contents">

        <div id="cart-items" style="display:flex;flex-direction:column;gap:1.25rem;margin-bottom:2.5rem;">
          {%- for item in cart.items -%}

            {%- assign is_subscribed = false -%}
            {%- if item.selling_plan_allocation -%}{%- assign is_subscribed = true -%}{%- endif -%}

            <div class="cart-item"
                 data-key="{{ item.key }}"
                 data-variant="{{ item.variant_id }}"
                 data-original-line-price="{{ item.line_price }}"
                 style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--card-radius);padding:1.25rem;transition:opacity 0.2s ease;">

              {%- comment -%} Main row: image + info + stepper {%- endcomment -%}
              <div style="display:grid;grid-template-columns:80px 1fr auto;gap:1.25rem;align-items:center;">

                {%- if item.image -%}
                  <img src="{{ item.image | img_url: '160x160', crop: 'center' }}"
                       alt="{{ item.title | escape }}" width="80" height="80"
                       style="border-radius:8px;object-fit:cover;">
                {%- else -%}
                  <div style="width:80px;height:80px;background:var(--color-surface-light);border-radius:8px;"></div>
                {%- endif -%}

                <div>
                  <p style="font-weight:600;margin-bottom:0.25rem;">{{ item.product.title }}</p>
                  {%- unless item.variant.title == 'Default Title' -%}
                    <p style="font-size:0.875rem;opacity:0.6;margin-bottom:0.25rem;">{{ item.variant.title }}</p>
                  {%- endunless -%}
                  {%- if item.selling_plan_allocation -%}
                    <p style="font-size:0.75rem;color:var(--color-accent);margin-bottom:0.25rem;">
                      ↻ {{ item.selling_plan_allocation.selling_plan.name }}
                    </p>
                  {%- endif -%}
                  <p class="item-line-price" style="display:flex;align-items:center;gap:0.5rem;flex-wrap:wrap;">
                    <s class="item-original-price" style="display:none;opacity:0.45;font-size:0.875rem;color:var(--color-text);text-decoration:line-through;">
                      {{ item.line_price | money }}
                    </s>
                    <span class="item-current-price" style="color:var(--color-accent);font-weight:600;">
                      {{ item.line_price | money }}
                    </span>
                  </p>
                </div>

                <div style="display:flex;flex-direction:column;align-items:flex-end;gap:0.75rem;">
                  <div style="display:flex;align-items:center;background:var(--color-surface-light);border:1px solid var(--color-border);border-radius:6px;overflow:hidden;">
                    <button type="button" class="qty-btn qty-minus" data-key="{{ item.key }}"
                            aria-label="Decrease quantity"
                            style="width:32px;height:36px;background:none;border:none;color:var(--color-text);font-size:1.125rem;cursor:pointer;display:flex;align-items:center;justify-content:center;">−</button>
                    <input type="number" class="qty-input" data-key="{{ item.key }}"
                           value="{{ item.quantity }}" min="0"
                           style="width:40px;background:transparent;border:none;color:var(--color-text);text-align:center;font-family:var(--font-body);font-size:0.9375rem;outline:none;-moz-appearance:textfield;">
                    <button type="button" class="qty-btn qty-plus" data-key="{{ item.key }}"
                            aria-label="Increase quantity"
                            style="width:32px;height:36px;background:none;border:none;color:var(--color-text);font-size:1.125rem;cursor:pointer;display:flex;align-items:center;justify-content:center;">+</button>
                  </div>
                  <button type="button" class="remove-item" data-key="{{ item.key }}"
                          style="font-size:0.75rem;opacity:0.45;text-decoration:underline;color:var(--color-text);background:none;border:none;cursor:pointer;padding:0;">
                    Remove
                  </button>
                </div>

              </div>

              {%- comment -%} Subscription toggle — compact, only shown if selling plans exist {%- endcomment -%}
              {%- if item.product.selling_plan_groups.size > 0 -%}
                <div style="margin-top:0.875rem;padding-top:0.875rem;border-top:1px solid var(--color-border);display:flex;align-items:center;gap:0.75rem;flex-wrap:wrap;">

                  {%- comment -%} Toggle — click handler on button, no hidden checkbox {%- endcomment -%}
                  <button type="button"
                          class="cart-sub-toggle"
                          data-key="{{ item.key }}"
                          data-on="{{ is_subscribed }}"
                          aria-pressed="{{ is_subscribed }}"
                          style="display:flex;align-items:center;gap:0.5rem;background:none;border:none;cursor:pointer;font-size:0.8125rem;font-weight:500;color:var(--color-text);padding:0;">
                    <span class="cart-sub-track" style="
                        display:inline-block;width:36px;height:20px;border-radius:10px;
                        background:{% if is_subscribed %}var(--color-accent){% else %}rgba(253,248,240,0.2){% endif %};
                        position:relative;transition:background 0.2s;flex-shrink:0;">
                      <span class="cart-sub-thumb" style="
                          position:absolute;top:2px;
                          left:{% if is_subscribed %}18px{% else %}2px{% endif %};
                          width:16px;height:16px;border-radius:50%;
                          background:#fff;transition:left 0.2s;display:block;"></span>
                    </span>
                    Subscribe &amp; Save
                  </button>

                  {%- comment -%} Interval dropdown — shown only when subscribed {%- endcomment -%}
                  <select class="cart-interval-select"
                          data-key="{{ item.key }}"
                          {% unless is_subscribed %}hidden{% endunless %}
                          style="background:var(--color-surface-light);border:1px solid var(--color-accent);border-radius:6px;color:var(--color-text);font-family:var(--font-body);font-size:0.8125rem;padding:0.3rem 0.6rem;cursor:pointer;outline:none;">
                    {%- for group in item.product.selling_plan_groups -%}
                      {%- for plan in group.selling_plans -%}
                        <option value="{{ plan.id }}"
                                {% if item.selling_plan_allocation.selling_plan.id == plan.id %}selected{% endif %}>
                          {{ plan.name }}
                        </option>
                      {%- endfor -%}
                    {%- endfor -%}
                  </select>

                </div>
              {%- endif -%}

            </div>
          {%- endfor -%}
        </div>

        {%- comment -%} Order summary {%- endcomment -%}
        <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--card-radius);padding:1.75rem;">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.25rem;">
            <span style="font-size:1.0625rem;">Subtotal</span>
            <span id="cart-subtotal" style="font-family:var(--font-heading);font-size:1.375rem;color:var(--color-accent);font-weight:700;">
              {{ cart.total_price | money }}
            </span>
          </div>
          <p style="font-size:0.8125rem;opacity:0.55;margin-bottom:1.5rem;">
            Free shipping · Taxes calculated at checkout.
          </p>
          <a href="/checkout" class="btn btn-primary btn-lg" style="width:100%;display:flex;justify-content:center;">
            Checkout — <span id="checkout-total" style="margin-left:0.3ch;">{{ cart.total_price | money }}</span>
          </a>
        </div>

        <p class="fda-disclaimer" style="margin-top:1.5rem;">
          {{ settings.fda_disclaimer }}
        </p>

      </div>

    {%- endif -%}

  </div>
</section>

<style>
  input[type=number]::-webkit-inner-spin-button,
  input[type=number]::-webkit-outer-spin-button { -webkit-appearance: none; }
  .qty-btn:hover { background: var(--color-border) !important; }
  .cart-item.is-loading { opacity: 0.4; pointer-events: none; }
</style>

<script>
(function() {

  function formatMoney(cents) {
    return '$' + (cents / 100).toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
  }

  function updateTotals(totalPrice) {
    const formatted = formatMoney(totalPrice);
    const subtotal  = document.getElementById('cart-subtotal');
    const checkout  = document.getElementById('checkout-total');
    if (subtotal) subtotal.textContent = formatted;
    if (checkout) checkout.textContent = formatted;
  }

  // Update price display. Pass the full line object from the Cart API.
  function updateLinePrice(key, line) {
    const item       = document.querySelector(`.cart-item[data-key="${key}"]`);
    if (!item) return;
    const currentEl  = item.querySelector('.item-current-price');
    const originalEl = item.querySelector('.item-original-price');
    if (!currentEl || !originalEl) return;

    const linePrice     = line.line_price;
    const originalPrice = line.original_line_price;
    const subscribed    = !!line.selling_plan_allocation;

    currentEl.textContent = formatMoney(linePrice);

    if (subscribed && originalPrice && originalPrice > linePrice) {
      originalEl.textContent = formatMoney(originalPrice);
      originalEl.style.display = 'inline';
    } else {
      originalEl.style.display = 'none';
    }
  }

  function removeItemFromDOM(key) {
    document.querySelector(`.cart-item[data-key="${key}"]`)?.remove();
    if (!document.querySelector('.cart-item')) {
      document.getElementById('cart-contents').innerHTML =
        '<div style="text-align:center;padding:4rem 0;">' +
        '<p style="font-size:1.125rem;opacity:0.7;margin-bottom:2rem;">Your cart is empty.</p>' +
        '<a href="/products/{{ settings.product_handle }}" class="btn btn-primary btn-lg">Shop Daily Reign</a>' +
        '</div>';
    }
  }

  async function changeCart(key, quantity, sellingPlan, toggleBtn) {
    const item = document.querySelector(`.cart-item[data-key="${key}"]`);
    if (item) item.classList.add('is-loading');

    const body = { id: key, quantity };
    if (sellingPlan) body.selling_plan = sellingPlan;

    let success = false;
    try {
      const res  = await fetch('/cart/change.js', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body:    JSON.stringify(body),
      });
      const data = await res.json();

      if (!data || typeof data.total_price !== 'number') {
        console.error('Cart API error:', data);
      } else {
        success = true;
        if (quantity === 0) {
          removeItemFromDOM(key);
        } else {
          const line = data.items?.find(i => i.key === key);
          if (line) updateLinePrice(key, line);
        }
        updateTotals(data.total_price);
        const countEl = document.querySelector('.cart-count');
        if (countEl) countEl.textContent = data.item_count;
      }
    } catch (err) {
      console.error('Cart error:', err);
    }

    item?.classList.remove('is-loading');

    // If API failed and this came from a toggle, revert the toggle UI
    if (!success && toggleBtn) revertToggle(toggleBtn, key);
  }

  function revertToggle(btn, key) {
    const isOn  = btn.dataset.on === 'true';
    const track = btn.querySelector('.cart-sub-track');
    const thumb = btn.querySelector('.cart-sub-thumb');
    const select = document.querySelector(`.cart-interval-select[data-key="${key}"]`);
    // Flip back
    btn.dataset.on = !isOn;
    track.style.background = !isOn ? 'var(--color-accent)' : 'rgba(253,248,240,0.2)';
    thumb.style.left       = !isOn ? '18px' : '2px';
    if (!isOn) select?.removeAttribute('hidden');
    else select?.setAttribute('hidden', '');
  }

  function getQty(key) {
    return parseInt(document.querySelector(`.qty-input[data-key="${key}"]`)?.value || '1', 10);
  }

  // ── Qty steppers ─────────────────────────────────────────────────────────
  document.querySelectorAll('.qty-plus, .qty-minus').forEach(btn => {
    btn.addEventListener('click', () => {
      const key   = btn.dataset.key;
      const input = document.querySelector(`.qty-input[data-key="${key}"]`);
      if (!input) return;
      const newQty = Math.max(0, parseInt(input.value, 10) + (btn.classList.contains('qty-plus') ? 1 : -1));
      input.value = newQty;
      changeCart(key, newQty);
    });
  });

  let debounce;
  document.querySelectorAll('.qty-input').forEach(input => {
    input.addEventListener('change', () => {
      clearTimeout(debounce);
      const key = input.dataset.key;
      const qty = Math.max(0, parseInt(input.value, 10) || 0);
      input.value = qty;
      debounce = setTimeout(() => changeCart(key, qty, undefined), 600);
    });
  });

  // ── Remove ───────────────────────────────────────────────────────────────
  document.querySelectorAll('.remove-item').forEach(btn => {
    btn.addEventListener('click', () => changeCart(btn.dataset.key, 0));
  });

  // ── Subscribe toggle — remove + re-add (only reliable way in Shopify) ───
  document.querySelectorAll('.cart-sub-toggle').forEach(btn => {
    btn.addEventListener('click', async () => {
      const key       = btn.dataset.key;
      const isOn      = btn.dataset.on === 'true';
      const nowOn     = !isOn;
      const variantId = document.querySelector(`.cart-item[data-key="${key}"]`)?.dataset.variant;
      const qty       = getQty(key);
      const select    = document.querySelector(`.cart-interval-select[data-key="${key}"]`);
      const planId    = nowOn ? (select?.value || null) : null;

      // Lock the item while working
      const item = document.querySelector(`.cart-item[data-key="${key}"]`);
      if (item) item.classList.add('is-loading');
      btn.disabled = true;

      try {
        // Step 1 — remove current line item
        await fetch('/cart/change.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: key, quantity: 0 }),
        });

        // Step 2 — re-add with or without selling plan
        const addBody = { items: [{ id: variantId, quantity: qty }] };
        if (planId) addBody.items[0].selling_plan = planId;

        await fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(addBody),
        });

        // Step 3 — reload so cart reflects real state
        window.location.reload();

      } catch (err) {
        console.error('Subscription toggle failed:', err);
        if (item) item.classList.remove('is-loading');
        btn.disabled = false;
      }
    });
  });

  // ── Interval select ──────────────────────────────────────────────────────
  document.querySelectorAll('.cart-interval-select').forEach(sel => {
    sel.addEventListener('change', () => {
      changeCart(sel.dataset.key, getQty(sel.dataset.key), sel.value);
    });
  });

})();
</script>

{% schema %}
{
  "name": "Cart",
  "tag": "section",
  "class": "section-cart",
  "settings": [],
  "presets": [{ "name": "Cart" }]
}
{% endschema %}

{%- comment -%}
  SECTION: collection-main
  Product grid for collection pages — /collections/all or any named collection.
  Each card links to the product page where full purchase options live.
{%- endcomment -%}

<section class="collection-page section-pad">
  <div class="container">

    <header style="margin-bottom:3rem;">
      <h1 style="font-family:var(--font-heading);font-size:clamp(2rem,4vw,3rem);margin-bottom:0.75rem;">
        {{- collection.title | default: 'All Products' -}}
      </h1>
      {%- if collection.description != blank -%}
        <p style="font-size:1.0625rem;opacity:0.75;max-width:600px;">{{ collection.description }}</p>
      {%- else -%}
        <p style="font-size:1.0625rem;opacity:0.75;max-width:600px;">
          {{ section.settings.fallback_description }}
        </p>
      {%- endif -%}
    </header>

    {%- if collection.products_count == 0 -%}
      <div style="text-align:center;padding:5rem 0;opacity:0.6;">
        <p style="font-size:1.125rem;">No products found in this collection.</p>
      </div>
    {%- else -%}
      <div class="collection-grid">
        {%- for product in collection.products -%}

          {%- assign has_sub = false -%}
          {%- if product.selling_plan_groups.size > 0 -%}{%- assign has_sub = true -%}{%- endif -%}

          <article class="product-card-tile">
            <a href="{{ product.url }}" class="product-card-tile__image-link" aria-label="{{ product.title | escape }}">
              {%- if product.featured_image -%}
                <img
                  src="{{ product.featured_image | img_url: '600x600', crop: 'center' }}"
                  alt="{{ product.featured_image.alt | default: product.title | escape }}"
                  width="600" height="600"
                  loading="lazy"
                  style="width:100%;height:100%;object-fit:cover;display:block;">
              {%- else -%}
                <div style="width:100%;height:100%;background:var(--color-surface-light);display:flex;align-items:center;justify-content:center;">
                  <span style="opacity:0.35;font-size:0.875rem;">No image</span>
                </div>
              {%- endif -%}
            </a>

            <div class="product-card-tile__info">
              <h2 class="product-card-tile__title">
                <a href="{{ product.url }}">{{ product.title }}</a>
              </h2>

              {%- if product.metafields.custom.subtitle != blank -%}
                <p class="product-card-tile__subtitle">{{ product.metafields.custom.subtitle }}</p>
              {%- endif -%}

              <div class="product-card-tile__price-row">
                <span class="product-card-tile__price">{{ product.price | money }}</span>
                {%- if has_sub -%}
                  <span class="product-card-tile__sub-badge">Subscribe &amp; Save</span>
                {%- endif -%}
              </div>

              <a href="{{ product.url }}" class="btn btn-primary" style="width:100%;display:flex;justify-content:center;margin-top:1rem;">
                Shop Now
              </a>
            </div>
          </article>

        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

<style>
  .collection-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2rem;
  }
  .product-card-tile {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--card-radius);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform var(--transition), box-shadow var(--transition);
  }
  .product-card-tile:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.25);
  }
  .product-card-tile__image-link {
    display: block;
    aspect-ratio: 1;
    overflow: hidden;
  }
  .product-card-tile__image-link img {
    transition: transform 0.4s ease;
  }
  .product-card-tile__image-link:hover img {
    transform: scale(1.03);
  }
  .product-card-tile__info {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .product-card-tile__title {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: 0.375rem;
  }
  .product-card-tile__title a {
    color: var(--color-text);
    text-decoration: none;
  }
  .product-card-tile__title a:hover {
    color: var(--color-accent);
  }
  .product-card-tile__subtitle {
    font-size: 0.875rem;
    opacity: 0.65;
    margin-bottom: 0.75rem;
  }
  .product-card-tile__price-row {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    flex-wrap: wrap;
    margin-top: auto;
  }
  .product-card-tile__price {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-accent);
  }
  .product-card-tile__sub-badge {
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-primary);
    background: var(--color-accent);
    border-radius: 4px;
    padding: 0.2rem 0.5rem;
  }
</style>

{% schema %}
{
  "name": "Collection Main",
  "tag": "section",
  "class": "section-collection-main",
  "settings": [
    {
      "type": "textarea",
      "id": "fallback_description",
      "label": "Fallback description (used when collection has no description)",
      "default": "Formulas chosen from the data. Each one selected for a specific community, a specific need, and a specific gap in mainstream wellness."
    }
  ],
  "presets": [{ "name": "Collection Main" }]
}
{% endschema %}
